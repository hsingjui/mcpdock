{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MCPDock",
  "version": "0.1.4",
  "identifier": "com.hsingjui.mcpdock",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "MCPDock",
        "width": 1120,
        "height": 720,
        "minWidth": 920,
        "minHeight": 640,
        "center": true,
        "visible": false,
        "focus": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 18,
          "y": 20
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; connect-src ipc://localhost tauri://localhost https://tauri.localhost",
      "dangerousDisableAssetCspModification": ["style-src"]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "dmg",
      "app"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFMTFFMjM5RDhBMzQyRkMKUldUOFFxUFlPZUlSWGpERUh1cy9ZUkJFdlh4dDRXcjB2UCtETGV0S1h1UHAzaHdaMmlDRit0RGMK",
      "endpoints": [
        "https://github.com/hsingjui/mcpdock/releases/latest/download/latest.json"
      ]
    }
  }
}
